---
// src/components/GoogleReviews.astro
import ReviewCard from './ReviewCard.astro';

const reviews = [
  {
    name: "Ulises Davila",
    date: "Hace 4 meses",
    text: "Muy buena experiencia, me solucionaron el gran problema que tenía de cucarachas, super recomendable",
